{
  "name": "@sumup/agent-toolkit",
  "version": "0.13.0",
  "homepage": "https://github.com/sumup/sumup-ai",
  "license": "Apache-2.0",
  "author": "SumUp <support@sumup.com> (https://sumup.com/)",
  "type": "module",
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib build --watch",
    "generate": "npm --prefix ../codegen run generate",
    "inspect": "rslib inspect",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "postgenerate": "npm run lint:fix",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sumup/sumup-ai.git"
  },
  "exports": {
    "./langchain": {
      "types": "./dist/langchain/index.d.ts",
      "require": "./dist/langchain/index.cjs",
      "import": "./dist/langchain/index.mjs"
    },
    "./openai": {
      "types": "./dist/openai/index.d.ts",
      "require": "./dist/openai/index.cjs",
      "import": "./dist/openai/index.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "require": "./dist/mcp/index.cjs",
      "import": "./dist/mcp/index.mjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "require": "./dist/ai/index.cjs",
      "import": "./dist/ai/index.mjs"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@langchain/core": "^1.1.49",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.11.6",
    "@sumup/sdk": "^0.1.6",
    "ai": "^6.0.207",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@rslib/core": "^0.23.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "jest": "^30.4.2",
    "rsbuild-plugin-publint": "^1.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "package.json",
    "dist/**/*"
  ]
}
