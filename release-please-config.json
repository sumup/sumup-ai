{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"include-component-in-tag": true,
	"draft": true,
	"extra-label": "release",
  "pull-request-title-pattern": "release: ${version}",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance Improvements"
    },
    {
      "type": "revert",
      "section": "Reverts"
    },
    {
      "type": "chore",
      "section": "Chores"
    },
    {
      "type": "docs",
      "section": "Documentation"
    },
    {
      "type": "style",
      "section": "Styles"
    },
    {
      "type": "refactor",
      "section": "Refactors"
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "build",
      "section": "Build System & Dependencies"
    },
    {
      "type": "ci",
      "section": "Continuous Integration",
      "hidden": true
    }
  ],
	"packages": {
		"mcp": {
			"release-type": "node",
			"component": "mcp"
		},
		"typescript": {
			"release-type": "node",
			"component": "typescript",
			"extra-files": [
				"src/common/const.ts",
        {
          "type": "json",
          "path": "jsr.json",
          "jsonpath": "$.version"
        }
			]
		}
	}
}
